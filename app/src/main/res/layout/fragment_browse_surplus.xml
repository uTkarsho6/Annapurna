<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <TextView
        android:id="@+id/tvBrowseTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Surplus Food Near You"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvBrowseSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Available listings, updated in real-time"
        android:textSize="13sp"
        android:textColor="@color/on_surface_variant"
        android:layout_marginStart="20dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvBrowseTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Loading Spinner -->
    <ProgressBar
        android:id="@+id/pbBrowse"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:indeterminateTint="@color/accent"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/tvBrowseSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Empty State Message -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No food available nearby right now."
        android:textSize="16sp"
        android:textColor="@color/on_surface_variant"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvBrowseSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Donation List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDonations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvBrowseSubtitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
